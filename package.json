{
  "name": "print2paper4vscode",
  "displayName": "Print2Paper4VSCode",
  "description": "Print selections or current tabs, including preview tabs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "publisher": "acoven",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/-entrypoint.js",
  "contributes": {
    "commands": [
      {
        "command": "p2p4vsc.print2paper",
        "title": "Print2Paper",
        "category": "Print"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "p2p4vsc.print2paper",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "p2p4vsc.print2paper",
        "key": "alt+p",
        "mac": "alt+p"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:deploy",
    "compile": "rm -rf out && tsc -p ./",
    "compile:deploy": "rm -rf out-deploy && tsc -p ./tsconfig.deploy.json",
    "lint": "eslint --config ./eslint.config.mjs src/**/*.ts",
    "lint:fix": "eslint --config ./eslint.config.mjs src/**/*.ts --fix",
    "lint:md": "markdownlint *.md tests/**/*.md",
    "lint:md:fix": "markdownlint *.md tests/**/*.md --fix",
    "format": "prettier --write src/**/*.ts **/*.md",
    "format:check": "prettier --check src/**/*.ts **/*.md",
    "test": "node --test out/tests/**/*.test.js",
    "test:watch": "node --test --watch out/tests/**/*.test.js",
    "test:verbose": "node --test --reporter spec out/tests/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "markdownlint-cli": "latest",
    "prettier": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@iarna/rtf-to-html": "^1.1.0",
    "crpdf": "^0.1.1",
    "rtf-parser": "latest",
    "shiki": "^3.11.0",
    "yaml": "latest"
  }
}
