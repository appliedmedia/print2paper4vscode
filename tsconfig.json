{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": ["ES2022", "DOM"],
        "sourceMap": true,

        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", ".vscode-test"]
}
