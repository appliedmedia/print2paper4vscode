{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": ["ES2022", "DOM"],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true
    },
    "exclude": ["node_modules", ".vscode-test", "tests"]
}
