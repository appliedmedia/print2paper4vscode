{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./out",
    "baseUrl": ".",
    "paths": {
      "*": ["src/types/*", "node_modules/@types/*"]
    },
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".vscode-test"]
}
