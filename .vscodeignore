# .vscodeignore - controls what ships in the .vsix to the marketplace.
# Whitelist mindset: the vsix should contain only dist/, README.md, CHANGELOG.md,
# LICENSE, package.json, and the icon. Everything else is dev-only.

# Source files (only ship compiled JS)
src/**
tests/**
features/**
config/**
scripts/**

# Site / docs / dev assets that are not user-facing
site/**
docs/**
!docs/MARKETPLACE.md
!docs/MARKETPLACE_CHANGELOG.md
zzz_archives/**
pocs/**
assets/**
# Walkthrough images must ship inside the VSIX (contributes.walkthroughs
# references local paths relative to package.json).
!assets/p2p4vsc-screenshots/**

# Images: ship only the marketplace icon. Exclude badges and other dev SVGs.
images/**
!images/logo-p2p4vsc_128x128px.png

# Build artifacts
out-deploy/
out/
coverage/
.tmp/
*.bak
*.template.bak

# Documentation: ship only the marketplace versions via vsce --readme-path
# / --changelog-path flags. Root README.md and CHANGELOG.md are dev-facing
# and would collide case-insensitively with the lowercase readme.md /
# changelog.md that vsce writes from those flags.
*.md

# Planning documents
edm-refactor-todos.md
fix-scroll.md
scrollpoc-impl.md
REFACTOR_TO_NAMED_PARAMS.md
Full_Render_with_PDF.js_Plan.md
PDF_GENERATION_FLOW.md
PDF_Initial_Refactor_and_Flow.md
DIAGNOSTICS_REFACTOR_PLAN.md
DIAGNOSTICS_USAGE_EXAMPLE.md
PR26.json

# Repo / tooling configuration
.github/**
.git/**
.gitignore
.gitattributes
.prettierrc
.stylelintrc.json
.markdownlintignore
.markdownlint.json
.eslintrc*
.editorconfig

# Dev dependencies
node_modules/**
.vscode/**
.cursor/**
.claude/**

# Environment
.env
.env.*
environment.json

# Test artifacts
*.test.ts
test-*.js
test-*.ts
vscode-mock.cjs
VSCODE_MOCK_INVESTIGATION.md

# Misc
*.log
.DS_Store
core
install-gh.sh
setup.sh
