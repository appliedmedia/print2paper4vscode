{
  "name": "print2paper4vscode",
  "displayName": "Print2Paper4VSCode",
  "description": "Print selections or current tabs with syntax highlighting and interactive PDF preview",
  "version": "1.0.0",
  "license": "SEE LICENSE IN FILE \"./LICENSE\"",
  "engines": {
    "vscode": "^1.90.0"
  },
  "publisher": "appliedmedia",
  "categories": [
    "Other"
  ],
  "keywords": [
    "print",
    "pdf",
    "syntax highlighting",
    "code printing",
    "export pdf",
    "shiki",
    "jspdf",
    "print preview",
    "code export"
  ],
  "repository": {
    "type": "git",
    "url": "https://p2p4vsc.dev"
  },
  "bugs": {
    "url": "https://p2p4vsc.support"
  },
  "homepage": "https://p2p4vsc.com",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "{{extId}}.print2paper",
        "title": "Print2Paper",
        "category": "Print"
      },
      {
        "command": "{{extId}}.persistClear",
        "title": "Clear State",
        "category": "Print"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "{{extId}}.print2paper",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "{{extId}}.print2paper",
          "group": "navigation",
          "when": "editorTextFocus",
          "title": "Print2Paper"
        }
      ]
    },
    "keybindings": [
      {
        "command": "{{extId}}.print2paper",
        "key": "alt+p",
        "mac": "alt+p"
      }
    ]
  },
  "scripts": {
    "postinstall": "node scripts/setup-vscode-mock.js",
    "vscode:prepublish": "bash scripts/prepublish.sh",
    "precompile": "node scripts/generate-package-json.mjs",
    "compile": "npm run precompile && rm -rf out && tsc -p ./.config/ && node scripts/templateDictReplace/templateDictReplace.mjs",
    "compile:deploy": "npm run precompile && rm -rf out && tsc -p ./.config/ && node scripts/templateDictReplace/templateDictReplace.mjs",
    "build": "npm run compile && npm run esbuild",
    "package": "bash scripts/prepublish.sh",
    "esbuild": "node .config/esbuild.mjs --production",
    "esbuild:watch": "node .config/esbuild.mjs --watch",
    "lint": "eslint --config ./.config/eslint.config.mjs src/**/*.ts",
    "lint:fix": "eslint --config ./.config/eslint.config.mjs src/**/*.ts --fix",
    "lint:md": "markdownlint *.md tests/**/*.md",
    "lint:md:fix": "markdownlint *.md tests/**/*.md --fix",
    "lint:yaml": "node scripts/lint-yaml-code.js",
    "lint:all": "npm run lint && npm run lint:md && npm run lint:yaml",
    "format": "prettier --write src/**/*.ts **/*.md",
    "format:check": "prettier --check src/**/*.ts **/*.md",
    "pretest": "node scripts/setup-vscode-mock.js",
    "test": "node --test out/tests/*.test.js",
    "test:gherkin": "node scripts/setup-vscode-mock.js && node --import @cucumber/node/bootstrap --test features/*.feature",
    "test:all": "node scripts/setup-vscode-mock.js && node --import @cucumber/node/bootstrap --test out/tests/*.test.js features/*.feature",
    "test:watch": "node --test --watch out/tests/**/*.test.js",
    "test:verbose": "node --test --reporter spec out/tests/**/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=json-summary npm run test:all",
    "test:coverage:check": "c8 --reporter=text --reporter=html --reporter=json-summary --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 npm run test:all"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "c8": "^10.1.3",
    "esbuild": "^0.27.1",
    "eslint": "latest",
    "htmlparser2": "^10.0.0",
    "js-yaml": "^4.1.0",
    "markdownlint-cli": "latest",
    "prettier": "latest",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@shikijs/vscode-textmate": "^10.0.2",
    "jspdf": "^3.0.3",
    "node-html-parser": "^7.0.1",
    "shiki": "^3.20.0",
    "vscode-oniguruma": "^2.0.1",
    "yaml": "latest"
  }
}
