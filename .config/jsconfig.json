{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["../src/**/*", "../out/**/*"],
  "exclude": ["node_modules", ".vscode-test", "out-deploy"]
}
